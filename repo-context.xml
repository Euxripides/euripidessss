)

type flowColumnMapping struct {
	SourceCol     string
	SourceAccount string
	SourceName    string
	SourceID      string
	SourceLabel   string
	TargetCol     string
	TargetCard    string
	TargetName    string
	TargetID      string
	TargetLabel   string
	Amount        string
	Time          string
	Direction     string
