  createDBImportTask,
  deleteDBConnection,
  editDBTable,
  executeDBQuery,
  listDBConnections,
  loadDBColumns,
  loadDBDatabases,
  loadDBSchemas,
  loadDBTables,
  previewDBTable,
  saveDBConnection,
  startDBImportTask,
  testDBConnection,
  type DBColumn,
  type DBConnection,
  type DBFieldMapping,
  type DBImportTask,
  type DBMappingRule,
  type DBTableRef,
} from './dbImportApi';
import './db-import.css';

type TableItem = { name: string; type: string };

const objectGroups = [
